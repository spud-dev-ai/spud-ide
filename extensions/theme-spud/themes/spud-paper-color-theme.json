	"//syntax": "disciplined monochrome — matches .sw-kw/fn/id/str/cmt/pun",
	"tokenColors": [
		{
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#9B988E"
			}
		},
		{
			"scope": "meta.embedded",
			"settings": { "foreground": "#1F1E17" }
		},
		{
			"name": "Variables / identifiers",
			"scope": ["variable", "meta.definition.variable.name", "support.variable", "string constant.other.placeholder"],
			"settings": { "foreground": "#3A392F" }
		},
		{
			"name": "Parameters",
			"scope": ["variable.parameter", "variable.parameter.function"],
			"settings": { "foreground": "#4A4942", "fontStyle": "italic" }
		},
		{
			"name": "Properties / object keys",
			"scope": ["variable.other.property", "support.variable.property", "meta.object.member", "meta.object-literal.key"],
			"settings": { "foreground": "#3A392F" }
		},
		{
			"name": "this / self",
			"scope": ["variable.language", "variable.language.this"],
			"settings": { "foreground": "#25355C", "fontStyle": "italic" }
		},
		{
			"name": "Keywords",
			"scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
			"settings": { "foreground": "#25355C", "fontStyle": "bold" }
		},
		{
			"name": "Operators",
			"scope": ["keyword.operator"],
			"settings": { "foreground": "#8A877C" }
		},
		{
			"name": "Import / export",
			"scope": ["keyword.control.import", "keyword.control.from", "keyword.control.export"],
			"settings": { "foreground": "#25355C", "fontStyle": "bold italic" }
		},
		{
			"name": "Strings",
			"scope": ["string", "string.quoted", "punctuation.definition.string"],
			"settings": { "foreground": "#5A6F3B" }
		},
		{
			"name": "Template string — embedded expression",
			"scope": ["meta.template.expression", "punctuation.definition.template-expression"],
			"settings": { "foreground": "#1F1E17" }
		},
		{
			"name": "Numbers / booleans",
			"scope": ["constant.numeric", "constant.language", "constant.language.boolean", "constant.language.null", "constant.language.undefined"],
			"settings": { "foreground": "#25355C" }
		},
		{
			"name": "Constants",
			"scope": ["constant", "variable.other.constant", "support.constant"],
			"settings": { "foreground": "#25355C" }
		},
		{
			"name": "Functions",
			"scope": ["entity.name.function", "support.function", "meta.function-call.generic", "variable.function"],
			"settings": { "foreground": "#1F1E17", "fontStyle": "bold" }
		},
		{
			"name": "Classes / types",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"support.class",
				"support.type",
				"entity.name.namespace",
				"entity.other.inherited-class"
			],
			"settings": { "foreground": "#1F1E17", "fontStyle": "bold" }
		},
		{
			"name": "Interfaces / enums",
			"scope": ["entity.name.type.interface", "entity.name.type.enum"],
			"settings": { "foreground": "#4A4942", "fontStyle": "bold" }
		},
		{
			"name": "Decorators",
			"scope": ["meta.decorator", "meta.decorator punctuation.decorator", "meta.decorator variable.other"],
			"settings": { "foreground": "#25355C", "fontStyle": "italic" }
		},
		{
			"name": "JSX tags",
			"scope": ["entity.name.tag", "meta.tag"],
			"settings": { "foreground": "#25355C" }
		},
		{
			"name": "Attributes",
			"scope": ["entity.other.attribute-name"],
			"settings": { "foreground": "#3A392F", "fontStyle": "italic" }
		},
		{
			"name": "JSON / YAML keys",
			"scope": ["support.type.property-name.json", "support.type.property-name.table", "entity.name.tag.yaml", "support.type.property-name"],
			"settings": { "foreground": "#1F1E17" }
		},
		{
			"name": "Regex",
			"scope": ["string.regexp", "constant.other.character-class.regexp", "constant.character.escape"],
			"settings": { "foreground": "#8F4031" }
		},
		{
			"name": "Punctuation",
			"scope": ["punctuation", "meta.brace"],
			"settings": { "foreground": "#8A877C" }
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.illegal"],
			"settings": { "foreground": "#8F4031", "fontStyle": "italic" }
		},
		{
			"name": "Markdown heading",
			"scope": ["markup.heading", "entity.name.section"],
			"settings": { "foreground": "#1F1E17", "fontStyle": "bold" }
		},
		{
			"name": "Markdown bold",
			"scope": ["markup.bold"],
			"settings": { "foreground": "#1F1E17", "fontStyle": "bold" }
		},
		{
			"name": "Markdown italic",
			"scope": ["markup.italic"],
			"settings": { "foreground": "#4A4942", "fontStyle": "italic" }
		},
		{
			"name": "Markdown link text",
			"scope": ["string.other.link", "markup.underline.link"],
			"settings": { "foreground": "#25355C" }
		},
		{
			"name": "Markdown inline code",
			"scope": ["markup.inline.raw", "markup.raw"],
			"settings": { "foreground": "#5A6F3B" }
		},
		{
			"name": "Markdown list",
			"scope": ["markup.list", "punctuation.definition.list.begin.markdown"],
			"settings": { "foreground": "#1F1E17" }
		},
		{
			"name": "Diff inserted",
			"scope": ["markup.inserted"],
			"settings": { "foreground": "#3E5E2B" }
		},
		{
			"name": "Diff deleted",
			"scope": ["markup.deleted"],
			"settings": { "foreground": "#8F4031" }
		},
		{
			"name": "Diff changed",
			"scope": ["markup.changed"],
			"settings": { "foreground": "#A08A4A" }
		},
		{
